APP_NAME=lead-conversion-sms-agent
ENV=dev
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=false

# Required
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/leads_db
REDIS_URL=redis://localhost:6379/0
ADMIN_TOKEN=change-me

# Optional here (can be configured in /ui Runtime Provider Settings)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

META_VERIFY_TOKEN=meta-verify-token
LINKEDIN_VERIFY_TOKEN=linkedin-verify-token

RQ_EAGER=false
RATE_LIMIT_COUNT=4
RATE_LIMIT_WINDOW_MINUTES=5
AFTER_HOURS_FOLLOWUP_MINUTES=720
