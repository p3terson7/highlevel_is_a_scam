APP_NAME=lead-conversion-sms-agent
ENV=dev
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=false

# Required
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/leads_db
REDIS_URL=redis://localhost:6379/0
POSTGRES_PASSWORD=postgres
ADMIN_TOKEN=
ENABLE_DEMO_SEED=false
# Compose binds the API to localhost by default. Set deliberately when a
# trusted reverse proxy or remote development host must reach it.
API_BIND_ADDRESS=127.0.0.1

# React is the default UI. Keep the legacy shell only as an explicit rollback.
UI_REACT_ISLAND_ENABLED=false
UI_REACT_APP_SHELL_ENABLED=true
# Emergency override; takes precedence over both React flags.
UI_LEGACY_SHELL_ENABLED=false
# `auto` is false only for dev/development/local/test/testing and true elsewhere.
# Production startup rejects an explicit false value.
UI_SECURE_COOKIES=auto
# Temporary server-client compatibility only. Browser login never returns a bearer token.
ENABLE_LEGACY_PORTAL_TOKEN_LOGIN=false

# Optional process defaults. Tenant channel settings are managed in Clients > Edit.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=
SMS_PROVIDER_MODE=auto
# Required in production. Use one or more comma-separated Fernet keys,
# newest first; retain old keys until stored secrets have been rotated.
SETTINGS_ENCRYPTION_KEYS=
# Optional demo-only outbound hook. Never commit a real Zapier catch URL.
STACKLEADS_ZAPIER_BOOKING_WEBHOOK_URL=
# Local manual curl testing only. Keep false for provider-connected or deployed environments.
ALLOW_UNSIGNED_TWILIO_WEBHOOKS=false
# Local loopback testing only. ENV=dev/local is not sufficient by itself.
ALLOW_UNSIGNED_CRM_WEBHOOKS=false

# Optional deployment fallbacks; prefer distinct per-client values in provider_config.
CRM_WEBHOOK_SECRET=
ZAPIER_BOOKING_WEBHOOK_SECRET=

# PHP public landing forms. These values must be exported to the PHP runtime;
# this file is an example and is not loaded automatically by plain PHP hosting.
# Blank inherits APP_ENV/ENV; set explicitly when PHP is deployed separately.
CRM_FORM_ENV=
CRM_FORM_PRODUCTION=false
CRM_WEBHOOK_URL=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAMES=
# A Redis URL and phpredis are required in production; rediss:// needs phpredis 5.3+.
CRM_RATE_LIMIT_REDIS_URL=
CRM_RATE_LIMIT_REDIS_PREFIX=3dpreciscan:form-rate
# Locked file limiting is local-only. Keep runtime directories outside the web root.
CRM_RATE_LIMIT_DIR=
CRM_UPLOAD_TMP_DIR=
CRM_TRUSTED_PROXY_IPS=
CRM_MAIL_FROM=website@3dpreciscan.com

# Global AI settings can also be configured in /ui.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_PROVIDER_MODE=auto

RQ_EAGER=false
# Aggregate authenticated inbound callbacks per tenant/Twilio account. Redis
# coordination is required outside local/test environments; outages fail closed.
TWILIO_INBOUND_TENANT_LIMIT=120
TWILIO_INBOUND_ACCOUNT_LIMIT=600
TWILIO_INBOUND_WINDOW_SECONDS=60
RATE_LIMIT_COUNT=60
RATE_LIMIT_WINDOW_MINUTES=1
# Pace automated replies without blocking an API or worker process. Set to 0
# only when immediate automated SMS delivery is explicitly desired.
AUTOMATED_SMS_DELAY_SECONDS=20
AFTER_HOURS_FOLLOWUP_MINUTES=720
REQUEST_TIMEOUT_SECONDS=20
REQUEST_BODY_MAX_BYTES=1048576
MESSAGE_MEDIA_MAX_BYTES=26214400
MESSAGE_MEDIA_STORAGE_DIR=storage/message_media
